# byteswarm configuration — VARIABLE NAMES ONLY, never real values.
# Copy to .env (gitignored) and fill in locally. CI secrets live in the CI
# provider's secret store, referenced by name (reference/security-fundamentals.md).

# --- byteswarm server (cmd/byteswarm) ---
# TCP address the authenticated /webhook ingress and the health endpoints listen
# on (ADR-0011). Cross-host and untrusted publishers use this.
BYTESWARM_HTTP_ADDR=

# --- Operator /events ingress (ADR-0011: Unix domain socket, defence-in-depth) ---
# The operator-local POST /events is served over a Unix socket whose file
# permissions are the access control, not the network. byteswarmctl dials this
# same path (BYTESWARM_EVENTS_SOCKET) instead of an http:// address.
# Path of the socket (default: byteswarm-events.sock, relative to the working dir).
BYTESWARM_EVENTS_SOCKET=
# Octal file mode for the socket (default: 0660 — owner + operator group).
BYTESWARM_EVENTS_SOCKET_MODE=
# Owning group for the socket (empty leaves the process's default group).
BYTESWARM_EVENTS_SOCKET_GROUP=

# --- Event bus (ADR-0004: NATS JetStream) ---
# URL of the NATS server; empty selects the in-process embedded server.
BYTESWARM_NATS_URL=

# --- State store (ADR-0005: PostgreSQL default / SQLite embedded) ---
# database/sql DSN. A postgres:// URL selects PostgreSQL; a file path selects SQLite.
BYTESWARM_DB_DSN=

# --- Webhook auth (ADR-0002: shared-secret adapter, fail-closed) ---
# Shared secret the webhook ingress requires on inbound requests.
BYTESWARM_WEBHOOK_SECRET=
