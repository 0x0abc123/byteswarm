flowchart TB
    bus["Event Bus<br/><i>[external system: NATS JetStream]</i>"]
    tools["External tools & processes<br/><i>[external system]</i>"]
    jobr["byteswarm-job<br/><i>[container: goja job-runner]</i>"]
    db[("State Store<br/><i>[db: PostgreSQL / SQLite]</i>")]
    pstore[("Plugin store<br/><i>[files: config + JS scripts + sandbox dirs]</i>")]

    subgraph srv [byteswarm Server — consumer subsystem]
        reg["Consumer registry<br/><i>[component: event type -> Consumer (port)]</i>"]
        evt["Event model & routing ports<br/><i>[component: event.Bus / event.Publisher]</i>"]
        repo["Repository (port)<br/><i>[component: per-aggregate state]</i>"]
        gocon["Native Go consumers<br/><i>[component: compile-time SDK]</i>"]
        host["Script-plugin host (goja)<br/><i>[component: ScriptConsumer + capability API]</i>"]
        loader["Plugin config loader<br/><i>[component: parse config, compile scripts]</i>"]
    end

    bus -->|"delivers subscribed events [via event.Bus]"| reg
    reg -->|"dispatches event [via Consumer port]"| gocon
    reg -->|"dispatches event [via Consumer port]"| host
