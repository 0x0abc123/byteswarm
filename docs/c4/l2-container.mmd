flowchart TB
    operator(["Operator<br/><i>engineer</i>"])
    pauthor(["Plugin author<br/><i>trusted dev</i>"])
    trigger["External trigger source<br/><i>[external system]</i>"]

    subgraph sys [byteswarm]
        cli["CLI<br/><i>[container: Go static binary]</i>"]
        srv["byteswarm Server<br/><i>[container: Go net/http + in-process Go & JS-script consumers]</i>"]
        bus["Event Bus<br/><i>[container: NATS JetStream]</i>"]
        db[("State Store<br/><i>[db: PostgreSQL default / SQLite embedded]</i>")]
        plugins[("Plugin store<br/><i>[files: config + JS scripts + per-plugin sandbox dirs]</i>")]
    end

    tools["External tools & processes<br/><i>[external system]</i>"]
    netsvc["External network services<br/><i>[external system]</i>"]
    sinks["Business-event sinks<br/><i>[external system]</i>"]
    logsink["Logging / monitoring sink<br/><i>[external system]</i>"]

    operator -->|"runs [shell]"| cli
    pauthor -->|"declares plugins & authors scripts [config + JS]"| plugins
    cli -->|"submits events & commands [JSON/HTTPS]"| srv
    trigger -->|"fires events (shared-secret auth) [webhook/HTTPS]"| srv
    srv -->|"loads plugin config & scripts, confines plugin file I/O [filesystem]"| plugins
    srv -->|"publishes events [NATS]"| bus
    bus -->|"delivers & redelivers events, at-least-once [NATS]"| srv
    srv -->|"reads/writes consumer & workflow state [SQL]"| db
    srv -->|"runs commands / launches processes [OS exec]"| tools
    srv -->|"reads from / sends data to [network]"| netsvc
    srv -->|"emits business events [consumer-defined]"| sinks
    srv -->|"ships errors/exceptions [structured logs]"| logsink

